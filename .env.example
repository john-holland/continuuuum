# Continuuuum library server (serve_library.py)
PORT=5050
CONTINUUUUM_DB_PATH=./continuuuum.db
CONTINUUUUM_LIBRARY_UPLOADS=./library_uploads

# Optional API auth for /api/library/*
CONTINUUUUM_API_KEY=

# Unity deeplink (written by Drawer 2 continuuuum_api when using episodic hub)
CONTINUUUUM_DEEPLINK_PATH=

# Background submit cron lives on continuuuum_api (Drawer 2), not serve_library
# CONTINUUUUM_SUBMIT_CRON=1

