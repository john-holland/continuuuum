# Continuum library server (serve_library.py)
PORT=5050
CONTINUUM_DB_PATH=./continuum.db
CONTINUUM_LIBRARY_UPLOADS=./library_uploads

# Optional API auth for /api/library/*
CONTINUUM_API_KEY=

# Unity deeplink (written by Drawer 2 continuum_api when using episodic hub)
CONTINUUM_DEEPLINK_PATH=

# Background submit cron lives on continuum_api (Drawer 2), not serve_library
# CONTINUUM_SUBMIT_CRON=1

# --- Deprecated: dual-server cross-links (remove after single-server merge) ---
# CONTINUUM_LEMMA_API_BASE=http://127.0.0.1:5051
# CONTINUUM_LIBRARY_BASE=http://127.0.0.1:5050

# Media / planet (optional)
# CONTINUUM_MEDIA_STORE_PATH=
# GOOGLE_MAPS_API_KEY=
